<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1"
     creator="Paikannusarvoitus"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xmlns:game="https://kempeleenlatu.fi/gpx-game"
     xsi:schemaLocation="http://www.topografix.com/GPX/1/1
                         http://www.topografix.com/GPX/1/1/gpx.xsd">

  <metadata>
    <name>Latu-arvoitus</name>

    <!-- topLeft  = maxlat + minlon (NW-kulma) -->
    <!-- bottomRight = minlat + maxlon (SE-kulma) -->
    <bounds minlat="64.897584" minlon="25.553005"
            maxlat="64.904190" maxlon="25.575948"/>

    <extensions>
      <game:mapImage>./kartta.png</game:mapImage>
      <game:geofenceRadius>15</game:geofenceRadius>
      <game:gpsAccuracyLimit>30</game:gpsAccuracyLimit>
      <game:checkAnswer>true</game:checkAnswer>
      <game:puzzleInstruction>Muodosta kerätyistä kirjaimista sana — mikä risteilee tällä alueella?</game:puzzleInstruction>
      <game:puzzleAnswer>LATU</game:puzzleAnswer>
    </extensions>
  </metadata>

  <!-- ═══ LOPPUPISTE (type=end) ═══════════════════════════════════════════ -->
  <wpt lat="64.901758" lon="25.562105">
    <name>Maali</name>
    <type>end</type>
    <desc>Olet kerännyt kaikki kirjaimet. Muodosta niistä sana — mikä risteilee tällä alueella?</desc>
  </wpt>

  <!-- ═══ KERÄILYPISTEET (type=collect) ══════════════════════════════════ -->

  <wpt lat="64.902791" lon="25.564495">
    <name>Takaparkki</name>
    <type>collect</type>
    <extensions>
      <game:id>1</game:id>
      <game:letter>A</game:letter>
      <game:hint>Täältä löytyy mm. WC — kätevä levähdyspaikka. Kirjaimesi on kuin huippu: kaksi jalkaa, yksi hattu.</game:hint>
    </extensions>
  </wpt>

  <wpt lat="64.901605" lon="25.568979">
    <name>Keinu</name>
    <type>collect</type>
    <extensions>
      <game:id>2</game:id>
      <game:letter>L</game:letter>
      <game:hint>Täällä voi keinua tai tehdä töitä etänä. Kirjaimesi seisoo tukevasti — suora pysty, leveä jalka.</game:hint>
    </extensions>
  </wpt>

  <wpt lat="64.900646" lon="25.559810">
    <name>Laavut</name>
    <type>collect</type>
    <extensions>
      <game:id>3</game:id>
      <game:letter>U</game:letter>
      <game:hint>Köykkyrin laavut ovat mainio paikka syödä eväitä. Kirjaimesi on kuin laavu — avoin ylhäältä, kutsuu sisään.</game:hint>
    </extensions>
  </wpt>

  <wpt lat="64.902200" lon="25.571910">
    <name>Nuotiopaikka</name>
    <type>collect</type>
    <extensions>
      <game:id>4</game:id>
      <game:letter>T</game:letter>
      <game:hint>Nuotiopaikka polun varressa — tuli lämmittää ja yhdistää. Kirjaimesi seisoo kuin teline: leveä hattu, suora selkä.</game:hint>
    </extensions>
  </wpt>

</gpx>
